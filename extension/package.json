{
  "name": "code-karma",
  "displayName": "Code Karma",
  "publisher": "mksho",
  "description": "Gamify code quality and track developer karma.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mksho/code-karma.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-karma.showDashboard",
        "title": "Code Karma: Show Dashboard"
      }
    ],
    "configuration": {
      "title": "Code Karma",
      "properties": {
        "codeKarma.rules.enableCommentRule": {
          "type": "boolean",
          "default": true,
          "description": "Award points for adding comments, or penalize for removing them."
        },
        "codeKarma.rules.enableConsoleLogPenalty": {
          "type": "boolean",
          "default": true,
          "description": "Penalize points for leaving console.log statements in your code."
        },
        "codeKarma.rules.cooldownMinutes": {
          "type": "number",
          "default": 3,
          "description": "Minutes to wait before another save on the same file can earn or lose karma (anti-spam)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0"
  },
  "dependencies": {
    "acorn": "^8.11.3",
    "acorn-walk": "^8.3.2"
  }
}
